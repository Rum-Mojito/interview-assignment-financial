      "cross_column_constraints": [
        {
          "constraint_id": "lead_score_given_new",
          "table": "leads",
          "when": {
            "column": "lead_status",
            "equals": "new"
          },
          "then": {
            "column": "lead_score",
            "distribution": {
              "type": "bucketed_int",
              "buckets": [
                { "min": 5, "max": 24, "weight": 0.38 },
                { "min": 25, "max": 40, "weight": 0.42 },
                { "min": 41, "max": 55, "weight": 0.2 }
              ]
            }
